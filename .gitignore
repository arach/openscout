# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
/site/.next/
/apps/*/.next/
/site/out/
/site/node_modules/
/landing/out/
/landing/node_modules/

# production
/build
/native/engine/.build
/native/engine/.derivedData
/native/dist
/native/engine/.swiftpm

# relay data (local state, not source)
.openscout/
.openscout/project.json
.openscout/relay/
.openscout/relay.json

# package build artifacts
packages/*/dist/
packages/*/node_modules/
apps/*/node_modules/
packages/relay/relay-docs/node_modules/
packages/relay/relay-docs/.astro/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
packages/relay/relay-docs/dist/

# iOS derived data / build artifacts
apps/ios/.derived-iphone/
apps/ios/.deriveddata/
apps/ios/$(pwd)/
apps/ios/.asc/artifacts/
*.xcuserstate
*.xcworkspace/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/
apps/ios/.asc/metadata/
apps/ios/build/

# hidden files / directories
/.*
**/.*
