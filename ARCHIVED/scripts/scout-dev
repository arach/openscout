#!/usr/bin/env bash

set -euo pipefail

SOURCE_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE_PATH" ]]; do
  SOURCE_DIR="$(cd "$(dirname "$SOURCE_PATH")" && pwd)"
  SOURCE_PATH="$(readlink "$SOURCE_PATH")"
  [[ "$SOURCE_PATH" != /* ]] && SOURCE_PATH="$SOURCE_DIR/$SOURCE_PATH"
done

SCRIPT_DIR="$(cd "$(dirname "$SOURCE_PATH")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
ENGINE_DIR="$ROOT_DIR/native/engine"
DERIVED_DATA_DIR="$ENGINE_DIR/.derivedData"
SUPPORT_DIR="$HOME/Library/Application Support/OpenScout"
APP_LOG_DIR="$SUPPORT_DIR/logs/app"
STATUS_FILE="$SUPPORT_DIR/agent-status.json"
APP_LOG_FILE="$APP_LOG_DIR/native.log"
AGENT_LOG_FILE="$APP_LOG_DIR/agent-host.log"
APP_BUNDLE_NAME="OpenScout.app"

mkdir -p "$SUPPORT_DIR" "$APP_LOG_DIR"

usage() {
  cat <<'EOF'
scout-dev: local developer CLI for OpenScout native targets

Usage:
  scout-dev build [app|agent|all]
  scout-dev rebuild [app|agent|all]
  scout-dev launch [app|agent|all]
  scout-dev relaunch [app|agent|all] [--rebuild]
  scout-dev quit [app|agent|all]
  scout-dev status [app|agent|all]

  scout-dev app <build|rebuild|launch|relaunch|quit|status|clean>
  scout-dev agent <build|rebuild|launch|relaunch|quit|status|clean>

  scout-dev doctor
  scout-dev paths
  scout-dev open-support
  scout-dev clean [app|agent|all]
  scout-dev help

Defaults:
  build/rebuild/status/quit/clean default to `all`
  launch/relaunch default to `all`
  `all` launch/relaunch uses ScoutApp as the stack entry point
  `scout-dev app` and `scout-dev agent` default to `launch`

Examples:
  scout-dev build app
  scout-dev build agent
  scout-dev launch app
  scout-dev launch agent
  scout-dev relaunch
  scout-dev relaunch app --rebuild
  scout-dev app status
  scout-dev agent quit
EOF
}

info() {
  printf '%s\n' "$*"
}

fail() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

is_target() {
  case "${1:-}" in
    app|agent|all)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

default_target_for_action() {
  case "$1" in
    build|rebuild|status|quit|clean|launch|relaunch)
      printf 'all\n'
      ;;
    *)
      fail "no default target for action: $1"
      ;;
  esac
}

assert_no_extra_args() {
  local context="$1"
  shift

  if [[ $# -gt 0 ]]; then
    fail "unexpected arguments for $context: $*"
  fi
}

find_binary() {
  local name="$1"
  find "$DERIVED_DATA_DIR/Build/Products" -path "*/Debug/$name" -type f 2>/dev/null | head -n 1
}

find_app_resource_bundle() {
  find "$DERIVED_DATA_DIR/Build/Products" -path "*/Debug/ScoutEngine_ScoutApp.bundle" -type d 2>/dev/null | head -n 1
}

find_app_bundle() {
  find "$DERIVED_DATA_DIR/Build/Products" -path "*/Debug/$APP_BUNDLE_NAME" -type d 2>/dev/null | head -n 1
}

build_relay_web() {
  info "Building Relay web workspace..."
  (
    cd "$ROOT_DIR"
    bun run relay-web:build
  )
}

package_app_bundle() {
  local app_bin agent_bin resource_bundle bundle_dir contents_dir macos_dir resources_dir plist_path

  app_bin="$(find_binary ScoutApp)"
  [[ -n "$app_bin" ]] || fail "ScoutApp binary not found after build."
  agent_bin="$(find_binary ScoutAgent)"
  [[ -n "$agent_bin" ]] || fail "ScoutAgent binary not found after build."

  resource_bundle="$(find_app_resource_bundle)"
  [[ -n "$resource_bundle" ]] || fail "ScoutApp resource bundle not found after build."

  bundle_dir="$(dirname "$app_bin")/$APP_BUNDLE_NAME"
  contents_dir="$bundle_dir/Contents"
  macos_dir="$contents_dir/MacOS"
  resources_dir="$contents_dir/Resources"
  plist_path="$contents_dir/Info.plist"

  rm -rf "$bundle_dir"
  mkdir -p "$macos_dir" "$resources_dir"

  cp "$app_bin" "$macos_dir/ScoutApp"
  chmod +x "$macos_dir/ScoutApp"
  cp "$agent_bin" "$macos_dir/ScoutAgent"
  chmod +x "$macos_dir/ScoutAgent"
  cp -R "$resource_bundle" "$resources_dir/"
  cp "$ENGINE_DIR/Sources/ScoutApp/Resources/AppIcon.icns" "$resources_dir/AppIcon.icns"

  cat >"$plist_path" <<'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleDevelopmentRegion</key>
  <string>en</string>
  <key>CFBundleDisplayName</key>
  <string>OpenScout</string>
  <key>CFBundleExecutable</key>
  <string>ScoutApp</string>
  <key>CFBundleIconFile</key>
  <string>AppIcon</string>
  <key>CFBundleIdentifier</key>
  <string>dev.openscout.native</string>
  <key>CFBundleInfoDictionaryVersion</key>
  <string>6.0</string>
  <key>CFBundleName</key>
  <string>OpenScout</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
  <key>CFBundleShortVersionString</key>
  <string>0.1.0</string>
  <key>CFBundleVersion</key>
  <string>1</string>
  <key>LSMinimumSystemVersion</key>
  <string>15.0</string>
  <key>NSHighResolutionCapable</key>
  <true/>
  <key>NSPrincipalClass</key>
  <string>NSApplication</string>
</dict>
</plist>
EOF

  info "Packaged app bundle: $bundle_dir"
}

build_target() {
  local scheme="$1"

  xcodebuild \
    -scheme "$scheme" \
    -configuration Debug \
    -derivedDataPath "$DERIVED_DATA_DIR" \
    -destination "platform=macOS" \
    build
}

clean_target() {
  local scheme="$1"

  xcodebuild \
    -scheme "$scheme" \
    -configuration Debug \
    -derivedDataPath "$DERIVED_DATA_DIR" \
    -destination "platform=macOS" \
    clean
}

build_selected() {
  local target="$1"

  case "$target" in
    app)
      info "Building ScoutApp and ScoutAgent..."
      (
        cd "$ENGINE_DIR"
        build_relay_web
        build_target ScoutApp
        build_target ScoutAgent
        package_app_bundle
      )
      ;;
    agent)
      info "Building ScoutAgent..."
      (
        cd "$ENGINE_DIR"
        build_target ScoutAgent
      )
      ;;
    all)
      info "Building Scout native targets..."
      (
        cd "$ENGINE_DIR"
        build_relay_web
        build_target ScoutApp
        build_target ScoutAgent
        package_app_bundle
      )
      ;;
    *)
      fail "unknown build target: $target"
      ;;
  esac
}

rebuild_selected() {
  local target="$1"

  case "$target" in
    app)
      info "Cleaning and rebuilding ScoutApp and ScoutAgent..."
      (
        cd "$ENGINE_DIR"
        build_relay_web
        clean_target ScoutApp
        clean_target ScoutAgent
        build_target ScoutApp
        build_target ScoutAgent
        package_app_bundle
      )
      ;;
    agent)
      info "Cleaning and rebuilding ScoutAgent..."
      (
        cd "$ENGINE_DIR"
        clean_target ScoutAgent
        build_target ScoutAgent
      )
      ;;
    all)
      clean_selected all
      build_selected all
      ;;
    *)
      fail "unknown rebuild target: $target"
      ;;
  esac
}

ensure_built_for_launch() {
  local target="$1"

  case "$target" in
    app|all)
      if [[ -z "$(find_binary ScoutApp)" || -z "$(find_binary ScoutAgent)" || -z "$(find_app_bundle)" ]]; then
        build_selected all
      fi
      ;;
    agent)
      if [[ -z "$(find_binary ScoutAgent)" ]]; then
        build_selected agent
      fi
      ;;
    *)
      fail "unknown launch target: $target"
      ;;
  esac
}

app_pids() {
  pgrep -f "/ScoutApp( |$)" || true
}

agent_pids() {
  pgrep -f "/ScoutAgent( |$)" || true
}

swift_wrapper_pids() {
  pgrep -f "swift run --package-path native/engine ScoutApp" || true
}

has_running_target() {
  local target="$1"

  case "$target" in
    app)
      [[ -n "$(app_pids)" || -n "$(swift_wrapper_pids)" ]]
      ;;
    agent)
      [[ -n "$(agent_pids)" ]]
      ;;
    all)
      [[ -n "$(app_pids)" || -n "$(agent_pids)" || -n "$(swift_wrapper_pids)" ]]
      ;;
    *)
      fail "unknown process target: $target"
      ;;
  esac
}

kill_target_once() {
  local target="$1"

  case "$target" in
    app)
      pkill -x ScoutApp 2>/dev/null || true
      pkill -f "/ScoutApp( |$)" 2>/dev/null || true
      pkill -f "swift run --package-path native/engine ScoutApp" 2>/dev/null || true
      ;;
    agent)
      pkill -x ScoutAgent 2>/dev/null || true
      pkill -f "/ScoutAgent( |$)" 2>/dev/null || true
      ;;
    all)
      kill_target_once app
      kill_target_once agent
      ;;
    *)
      fail "unknown process target: $target"
      ;;
  esac
}

force_kill_target() {
  local target="$1"

  case "$target" in
    app)
      pkill -9 -x ScoutApp 2>/dev/null || true
      pkill -9 -f "/ScoutApp( |$)" 2>/dev/null || true
      pkill -9 -f "swift run --package-path native/engine ScoutApp" 2>/dev/null || true
      ;;
    agent)
      pkill -9 -x ScoutAgent 2>/dev/null || true
      pkill -9 -f "/ScoutAgent( |$)" 2>/dev/null || true
      ;;
    all)
      force_kill_target app
      force_kill_target agent
      ;;
    *)
      fail "unknown process target: $target"
      ;;
  esac
}

target_label() {
  case "$1" in
    app)
      printf 'ScoutApp'
      ;;
    agent)
      printf 'ScoutAgent'
      ;;
    all)
      printf 'Scout stack'
      ;;
    *)
      printf '%s' "$1"
      ;;
  esac
}

clear_agent_status_if_stopped() {
  if [[ -z "$(agent_pids)" ]]; then
    rm -f "$STATUS_FILE"
  fi
}

quit_selected() {
  local target="$1"

  if ! has_running_target "$target"; then
    if [[ "$target" == "agent" || "$target" == "all" ]]; then
      clear_agent_status_if_stopped
    fi

    info "No running $(target_label "$target") processes."
    return
  fi

  info "Stopping $(target_label "$target")..."

  for _ in $(seq 1 20); do
    kill_target_once "$target"

    if ! has_running_target "$target"; then
      return
    fi

    sleep 0.1
  done

  force_kill_target "$target"

  if [[ "$target" == "agent" || "$target" == "all" ]]; then
    clear_agent_status_if_stopped
  fi
}

launch_app() {
  ensure_built_for_launch app

  if [[ -n "$(app_pids)" ]]; then
    info "ScoutApp is already running."
    return
  fi

  local app_bundle
  app_bundle="$(find_app_bundle)"
  [[ -n "$app_bundle" ]] || fail "OpenScout app bundle not found after build."

  info "Launching OpenScout.app..."
  open -n "$app_bundle"
  info "OpenScout app bundle: $app_bundle"
}

launch_agent() {
  ensure_built_for_launch agent

  if [[ -n "$(agent_pids)" ]]; then
    info "ScoutAgent is already running."
    return
  fi

  local agent_bin
  agent_bin="$(find_binary ScoutAgent)"
  [[ -n "$agent_bin" ]] || fail "ScoutAgent binary not found after build."

  rm -f "$STATUS_FILE"
  info "Launching ScoutAgent..."
  nohup "$agent_bin" --status-file "$STATUS_FILE" </dev/null >"$AGENT_LOG_FILE" 2>&1 &
  info "ScoutAgent log: $AGENT_LOG_FILE"
}

launch_selected() {
  local target="$1"

  case "$target" in
    app|all)
      launch_app
      ;;
    agent)
      launch_agent
      ;;
    *)
      fail "unknown launch target: $target"
      ;;
  esac
}

relaunch_selected() {
  local target="$1"
  shift
  local rebuild=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --rebuild)
        rebuild=1
        ;;
      *)
        fail "unexpected arguments for 'scout-dev relaunch $target': $1"
        ;;
    esac
    shift
  done

  if [[ "$rebuild" == "1" ]]; then
    case "$target" in
      app)
        quit_selected app
        rebuild_selected app
        launch_app
        ;;
      agent)
        quit_selected agent
        rebuild_selected agent
        launch_agent
        ;;
      all)
        quit_selected all
        rebuild_selected all
        launch_app
        ;;
      *)
        fail "unknown relaunch target: $target"
        ;;
    esac
    return
  fi

  case "$target" in
    app)
      quit_selected app
      launch_app
      ;;
    agent)
      quit_selected agent
      launch_agent
      ;;
    all)
      quit_selected all
      launch_app
      ;;
    *)
      fail "unknown relaunch target: $target"
      ;;
  esac
}

print_header_paths() {
  info "Support directory: $SUPPORT_DIR"
  info "Status file: $STATUS_FILE"
  info "App log: $APP_LOG_FILE"
  info "Agent log: $AGENT_LOG_FILE"
}

print_pid_block() {
  local label="$1"
  local pids="$2"

  if [[ -n "$pids" ]]; then
    info "$label PIDs:"
    printf '%s\n' "$pids"
  else
    info "$label: not running"
  fi
}

heartbeat_health() {
  python3 - <<'PY' "$STATUS_FILE"
import json
import os
import sys
import time

path = sys.argv[1]
with open(path, "r", encoding="utf-8") as f:
    data = json.load(f)

pid = data.get("pid")
heartbeat = data.get("heartbeat")
detail = data.get("detail", "")
state = data.get("state", "unknown")

alive = bool(pid) and os.path.exists(f"/proc/{pid}") if sys.platform.startswith("linux") else True
if sys.platform == "darwin" and pid:
    alive = os.system(f"kill -0 {pid} >/dev/null 2>&1") == 0

age = None
if isinstance(heartbeat, (int, float)):
    age = max(0.0, time.time() - (heartbeat + 978307200))

print(f"Heartbeat state: {state}")
if pid:
    print(f"Heartbeat pid: {pid} ({'alive' if alive else 'stale'})")
if age is not None:
    freshness = "fresh" if age < 5 else "stale"
    print(f"Heartbeat age: {age:.1f}s ({freshness})")
if detail:
    print(f"Heartbeat detail: {detail}")
PY
}

print_heartbeat_block() {
  if [[ -f "$STATUS_FILE" ]]; then
    info "Heartbeat:"
    cat "$STATUS_FILE"
    info ""
    heartbeat_health
  else
    info "Heartbeat: missing"
  fi
}

print_status_selected() {
  local target="$1"

  case "$target" in
    app)
      info "Support directory: $SUPPORT_DIR"
      info "App log: $APP_LOG_FILE"
      info ""
      print_pid_block "ScoutApp" "$(app_pids)"
      ;;
    agent)
      info "Support directory: $SUPPORT_DIR"
      info "Status file: $STATUS_FILE"
      info "Agent log: $AGENT_LOG_FILE"
      info ""
      print_pid_block "ScoutAgent" "$(agent_pids)"
      info ""
      print_heartbeat_block
      ;;
    all)
      print_header_paths
      info ""
      print_pid_block "ScoutApp" "$(app_pids)"
      print_pid_block "ScoutAgent" "$(agent_pids)"
      info ""
      print_heartbeat_block
      ;;
    *)
      fail "unknown status target: $target"
      ;;
  esac
}

print_paths() {
  info "Repo root: $ROOT_DIR"
  info "Engine directory: $ENGINE_DIR"
  info "Derived data: $DERIVED_DATA_DIR"
  info "Support directory: $SUPPORT_DIR"
  info "Status file: $STATUS_FILE"
  info "App log: $APP_LOG_FILE"
  info "Agent log: $AGENT_LOG_FILE"
  info "ScoutApp binary: $(find_binary ScoutApp || true)"
  info "OpenScout app bundle: $(find_app_bundle || true)"
  info "ScoutAgent binary: $(find_binary ScoutAgent || true)"
}

doctor() {
  ensure_built_for_launch all
  print_status_selected all
}

open_support() {
  mkdir -p "$SUPPORT_DIR"
  open "$SUPPORT_DIR"
}

clean_selected() {
  local target="$1"

  case "$target" in
    app)
      info "Cleaning ScoutApp artifacts..."
      (
        cd "$ENGINE_DIR"
        clean_target ScoutApp
      )
      ;;
    agent)
      info "Cleaning ScoutAgent artifacts..."
      (
        cd "$ENGINE_DIR"
        clean_target ScoutAgent
      )
      ;;
    all)
      quit_selected all
      info "Removing native build artifacts..."
      rm -rf "$ENGINE_DIR/.build" "$DERIVED_DATA_DIR"
      ;;
    *)
      fail "unknown clean target: $target"
      ;;
  esac
}

dispatch_action() {
  local action="$1"
  local target="$2"
  shift 2

  case "$action" in
    build)
      assert_no_extra_args "'scout-dev $action $target'" "$@"
      build_selected "$target"
      ;;
    rebuild)
      assert_no_extra_args "'scout-dev $action $target'" "$@"
      rebuild_selected "$target"
      ;;
    launch)
      assert_no_extra_args "'scout-dev $action $target'" "$@"
      launch_selected "$target"
      ;;
    relaunch)
      relaunch_selected "$target" "$@"
      ;;
    quit)
      assert_no_extra_args "'scout-dev $action $target'" "$@"
      quit_selected "$target"
      ;;
    status)
      assert_no_extra_args "'scout-dev $action $target'" "$@"
      print_status_selected "$target"
      ;;
    clean)
      assert_no_extra_args "'scout-dev $action $target'" "$@"
      clean_selected "$target"
      ;;
    *)
      fail "unknown action: $action"
      ;;
  esac
}

main() {
  local command="${1:-help}"

  case "$command" in
    help|-h|--help)
      usage
      ;;
    doctor)
      shift
      assert_no_extra_args "'scout-dev doctor'" "$@"
      doctor
      ;;
    paths)
      shift
      assert_no_extra_args "'scout-dev paths'" "$@"
      print_paths
      ;;
    open-support)
      shift
      assert_no_extra_args "'scout-dev open-support'" "$@"
      open_support
      ;;
    app|agent)
      local target="$command"
      local action="${2:-launch}"

      if [[ $# -gt 1 ]]; then
        shift 2
      else
        shift 1
      fi

      dispatch_action "$action" "$target" "$@"
      ;;
    all)
      local action="${2:-status}"

      if [[ $# -gt 1 ]]; then
        shift 2
      else
        shift 1
      fi

      dispatch_action "$action" all "$@"
      ;;
    build|rebuild|launch|relaunch|quit|status|clean)
      local action="$command"
      local target="${2:-}"

      if is_target "$target"; then
        shift 2
      else
        target="$(default_target_for_action "$action")"
        shift 1
      fi

      dispatch_action "$action" "$target" "$@"
      ;;
    *)
      fail "unknown command: $command"
      ;;
  esac
}

main "$@"
