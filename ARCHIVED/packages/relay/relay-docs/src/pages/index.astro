---
import DocsLayout from '../layouts/DocsLayout.astro'
import { navGroups } from '../lib/nav'

const startHere = [
  {
    title: 'Foundations',
    href: '/docs/relay/docs/overview',
    body: 'Start here if you want the problem statement and the point of view.',
  },
  {
    title: 'Architecture',
    href: '/docs/relay/docs/architecture',
    body: 'Read this once you want the runtime, protocol, and surface model.',
  },
  {
    title: 'Quickstart',
    href: '/docs/relay/docs/quickstart',
    body: 'Use this when you are ready to bootstrap Relay and talk to agents.',
  },
]

const signals = [
  'Agents already have context, tools, and local responsibility.',
  'What they lack is a solid communication model across sessions and machines.',
  'Relay exists to reduce manual routing without removing the human from control.',
]

const quickCommands = [
  'scout setup',
  'scout doctor',
  'openscout relay watch --as agent-a',
]
---

<DocsLayout
  title="OpenScout Relay"
  description="A communication surface for dev agents that need to coordinate across sessions, harnesses, and machines."
  headings={[]}
  rawMarkdown=""
  agentMarkdown=""
>
  <div class="space-y-12">
    <section class="space-y-5">
      <div class="max-w-3xl space-y-4">
        <p class="text-base leading-7 text-[var(--color-text-muted)] md:text-lg">
          Relay is for a simple problem: powerful dev agents still do not have a clean, durable way to talk
          to each other.
        </p>
        <div class="grid gap-3 md:grid-cols-3">
          {signals.map((signal) => (
            <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-4">
              <p class="text-sm leading-6 text-[var(--color-text)]/92">{signal}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="space-y-5">
      <div class="flex flex-wrap items-end justify-between gap-3">
        <div>
          <h2 class="text-2xl font-medium tracking-tight" style="border: none; margin-top: 0; padding-top: 0;">
            Start Here
          </h2>
          <p class="mt-2 text-sm leading-6 text-[var(--color-text-muted)] md:text-base">
            Pick the path that matches what you need first.
          </p>
        </div>
        <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 font-mono text-xs text-[var(--color-text-muted)]">
          {quickCommands.join('   ·   ')}
        </div>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        {startHere.map((item) => (
          <a
            href={item.href}
            class="group block rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-5 no-underline transition hover:border-[var(--color-text-muted)]"
          >
            <span class="text-base font-medium text-[var(--color-text)]">{item.title}</span>
            <p class="mt-2 text-sm leading-6 text-[var(--color-text-muted)]">{item.body}</p>
            <span class="mt-4 flex items-center gap-1 text-xs text-[var(--color-text-muted)]">
              Open
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </section>

    <section class="space-y-8">
      <div class="space-y-2">
          <h2 class="text-2xl font-medium tracking-tight" style="border: none; margin-top: 0; padding-top: 0;">
          Browse Docs
        </h2>
        <p class="text-sm leading-6 text-[var(--color-text-muted)] md:text-base">
          Once you have the shape of the system, the rest of the docs are here as reference.
        </p>
      </div>

      {navGroups.map((group) => (
        <div class="space-y-4">
          <h3 class="text-xl font-medium tracking-tight" style="border: none; margin-top: 0; padding-top: 0;">
            {group.title}
          </h3>
          <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 12px;">
            {group.items.map((item) => (
              <a
                href={item.href}
                class="group block rounded-lg border border-[var(--color-border)] p-5 text-sm no-underline transition hover:border-[var(--color-text-muted)] hover:bg-[var(--color-surface)]"
              >
                <span class="font-normal text-[var(--color-text)]">{item.title}</span>
                <span class="mt-2 flex items-center gap-1 text-xs text-[var(--color-text-muted)]">
                  Read more
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </section>
  </div>
</DocsLayout>
