  "nodeData": {
    "register": { "icon": "FileText",  "name": "Register", "subtitle": "Override entry",  "color": "slate" },
    "start":    { "icon": "Play",      "name": "Start",    "subtitle": "Launch harness",  "color": "amber" },
    "route":    { "icon": "GitBranch", "name": "Route",    "subtitle": "Resolve @agent",  "color": "violet" },
    "invoke":   { "icon": "Zap",       "name": "Invoke",   "subtitle": "Flight record",   "color": "blue" },
    "stop":     { "icon": "Square",    "name": "Stop",     "subtitle": "Terminate",       "color": "slate" },
