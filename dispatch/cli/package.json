{
  "name": "@openscout/dispatch",
  "version": "0.1.0",
  "description": "Dispatch CLI for OpenScout",
  "license": "UNLICENSED",
  "type": "module",
  "bin": {
    "dispatch": "./bin/dispatch.mjs"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "mkdir -p dist && bun build ./src/main.ts --target=node --outfile ./dist/main.mjs",
    "dispatch": "bun src/cli.ts",
    "start": "bun src/main.ts start",
    "pair": "bun src/main.ts pair",
    "bridge": "bun src/bridge/main.ts",
    "relay": "bun src/main.ts relay",
    "config": "bun src/main.ts config",
    "status": "bun src/main.ts status",
    "prepack": "bun run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@noble/ciphers": "^2.1.1",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "uqr": "^0.1.2"
  }
}
