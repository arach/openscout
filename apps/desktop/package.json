{
  "name": "@scout/app",
  "version": "0.2.10",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/app/index.ts",
      "default": "./src/app/index.ts"
    },
    "./desktop": {
      "types": "./src/desktop.ts",
      "default": "./src/desktop.ts"
    },
    "./product": {
      "types": "./src/product.ts",
      "default": "./src/product.ts"
    },
    "./scout-desktop": {
      "types": "./src/scout-desktop.ts",
      "default": "./src/scout-desktop.ts"
    }
  },
  "bin": {
    "scout": "./bin/scout.ts",
    "pair-supervisor": "./bin/pair-supervisor.ts"
  },
  "files": [
    "bin",
    "README.md"
  ],
  "scripts": {
    "check": "bunx tsc -p tsconfig.json",
    "scout": "bun ./bin/scout.ts",
    "test:happy": "bun test src/core/pairing/runtime/bridge/fileserver.test.ts"
  },
  "devDependencies": {
    "bun-types": "^1.3.11"
  },
  "dependencies": {
    "@hono/trpc-server": "^0.4.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@noble/ciphers": "^2.1.1",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@openscout/agent-sessions": "workspace:*",
    "@openscout/protocol": "workspace:*",
    "@openscout/runtime": "workspace:*",
    "@openscout/session-trace": "workspace:*",
    "@openscout/session-trace-react": "workspace:*",
    "@openscout/tail": "workspace:*",
    "@trpc/client": "^11.16.0",
    "@opentui/core": "^0.1.88",
    "@opentui/react": "^0.1.88",
    "@trpc/server": "^11.16.0",
    "clsx": "^2.1.1",
    "hono": "^4.12.10",
    "trpc-bun": "^0.1.0",
    "uqr": "^0.1.2",
    "zod": "^4.3.6"
  }
