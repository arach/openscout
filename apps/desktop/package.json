{
  "name": "@scout/app",
  "version": "0.2.10",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/app/index.ts",
      "default": "./src/app/index.ts"
    },
    "./desktop": {
      "types": "./src/desktop.ts",
      "default": "./src/desktop.ts"
    },
    "./product": {
      "types": "./src/product.ts",
      "default": "./src/product.ts"
    },
    "./scout-desktop": {
      "types": "./src/scout-desktop.ts",
      "default": "./src/scout-desktop.ts"
    },
    "./web-entry-client": {
      "types": "./src/web-entry-client.tsx",
      "default": "./src/web-entry-client.tsx"
    },
    "./web-entry-server": {
      "types": "./src/web-entry-server.tsx",
      "default": "./src/web-entry-server.tsx"
    }
  },
  "bin": {
    "scout": "./bin/scout.ts",
    "pair-supervisor": "./bin/pair-supervisor.ts"
  },
  "files": [
    "bin",
    "README.md"
  ],
  "scripts": {
    "check": "bunx tsc -p tsconfig.json",
    "scout": "bun ./bin/scout.ts",
    "web:build": "vite build --outDir dist/client",
    "dev:web": "node ./scripts/dev-web.mjs",
    "web": "bun run ./src/server/index.ts",
    "test:happy": "bun test src/core/pairing/runtime/bridge/fileserver.test.ts"
  },
