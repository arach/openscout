<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Unsandboxed: Scout Menu supervises local services, HUD surfaces, and terminal integrations. -->
    <key>com.apple.security.app-sandbox</key>
    <false/>

    <!-- Local broker/web voice bridge. -->
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- Apple Events support terminal discovery/focus from the HUD. -->
    <key>com.apple.security.automation.apple-events</key>
    <true/>

    <!-- Microphone capture lives in Scout Menu, not the main Scout UI app. -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
