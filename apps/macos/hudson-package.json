{
  "macos": {
    "productName": "OpenScout",
    "packageJson": "../../package.json",
    "distDir": "dist",
    "minimumSystemVersion": "14.0",
    "features": ["terminal", "voice"],
    "builds": [
      {
        "command": "swift",
        "args": ["build", "-c", "release"],
        "cwd": ".",
        "features": ["terminal", "voice"]
      }
    ],
    "signing": {
      "identityEnv": "OPENSCOUT_SIGN_IDENTITY",
      "notaryProfileEnv": "OPENSCOUT_NOTARY_PROFILE",
      "requireIdentity": true
    },
    "apps": [
      {
        "name": "OpenScout",
        "bundleName": "OpenScout.app",
        "displayName": "OpenScout",
        "product": "Scout",
        "executableName": "Scout",
        "binaryPath": ".build/release/Scout",
        "infoPlist": "ScoutInfo.plist",
        "bundleIdentifier": "app.openscout.scout",
        "icon": "../../apps/desktop/public/scout-icon.png",
        "embeddedHelpers": [
          {
            "name": "Scout Menu",
            "bundleName": "ScoutMenu.app",
            "displayName": "Scout Menu",
            "product": "ScoutMenu",
            "executableName": "ScoutMenu",
            "binaryPath": ".build/release/ScoutMenu",
            "infoPlist": "Info.plist",
            "bundleIdentifier": "app.openscout.scout.menu",
            "lsuiElement": true,
            "icon": "../../apps/desktop/public/scout-menu-icon.png",
            "destination": "Contents/Library/LoginItems"
          }
        ]
      }
    ],
    "dmg": {
      "name": "OpenScout-${version}.dmg",
      "latestName": "OpenScout.dmg",
      "volumeName": "OpenScout",
      "title": "OpenScout",
      "subtitle": "Slack for agents",
      "accent": "#B7F34A",
      "backgroundColor": "#0B0F14",
      "gridColor": "#263241",
      "cornerBrackets": "all",
      "bracketInset": 40,
      "bracketLength": 20,
      "bracketTop": 20,
      "bracketBottomY": 348,
      "bracketStroke": 1,
      "shelfInset": 52,
      "shelfTop": 196,
      "installLabelY": 174,
      "width": 680,
      "height": 400,
      "iconSize": 96,
      "positions": [
        { "name": "OpenScout.app", "x": 190, "y": 250 },
        { "name": "Applications", "x": 500, "y": 250 }
      ]
    }
  }
}
