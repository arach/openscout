{
  "name": "openscout",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "openscout-dev": "./scripts/openscout-dev"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "packages/*",
    "dispatch/cli"
  ],
  "scripts": {
    "dev": "bun run electron:dev",
    "build": "bun run electron:build",
    "check": "bun run protocol:check && bun run electron:check && bun run runtime:check",
    "dispatch:pair": "bun run --cwd dispatch/cli pair",
    "dispatch:start": "bun run --cwd dispatch/cli start",
    "dispatch:relay": "bun run --cwd dispatch/cli relay",
    "dispatch:config": "bun run --cwd dispatch/cli config",
    "dispatch:status": "bun run --cwd dispatch/cli status",
    "start": "bun run electron",
    "electron": "bun run --cwd packages/electron-app electron",
    "electron:build": "bun run protocol:build && bun run runtime:build && bun run --cwd packages/electron-app build && bun run --cwd packages/electron-app build:electron",
    "electron:check": "bun run --cwd packages/electron-app check",
    "electron:dev": "bun run --cwd packages/electron-app dev",
    "electron:import-v0": "bun run --cwd packages/electron-app import:v0",
    "electron:stage-v0": "bun run --cwd packages/electron-app stage:v0",
    "electron:diff-v0": "bun run --cwd packages/electron-app diff:v0",
    "electron:apply-v0": "bun run --cwd packages/electron-app apply:v0",
    "electron:package": "bun run --cwd packages/electron-app package:macos",
    "electron:web": "bun run --cwd packages/electron-app electron:web",
    "openscout:build": "./scripts/openscout-dev build",
    "openscout:launch": "./scripts/openscout-dev launch",
    "openscout:relaunch": "./scripts/openscout-dev relaunch",
    "openscout:quit": "./scripts/openscout-dev quit",
    "openscout:status": "./scripts/openscout-dev status",
    "openscout:logs": "./scripts/openscout-dev logs",
    "site": "bun run site:dev",
    "site:dev": "next dev",
    "site:build": "next build",
    "site:start": "next start",
    "build:docs": "cd packages/relay/relay-docs && bun install && bun run build && mkdir -p ../../../out/docs/relay && cp -r dist/* ../../../out/docs/relay/",
    "docs:build": "bun run build:docs",
    "lint": "eslint",
    "cli:build": "bun run protocol:build && bun run runtime:build && bun run --cwd packages/cli build",
    "cli:dev": "bun run --cwd packages/cli dev",
    "protocol:build": "bun run --cwd packages/protocol build",
    "protocol:check": "bun run --cwd packages/protocol check",
    "relay:build": "bun run protocol:build && bun run --cwd packages/relay build",
    "relay:dev": "bun run --cwd packages/relay dev",
    "relay:tui": "bun run --cwd packages/relay tui",
    "runtime:broker": "bun run --cwd packages/runtime broker",
    "runtime:build": "bun run protocol:build && bun run --cwd packages/runtime build",
    "runtime:check": "bun run --cwd packages/runtime check",
    "runtime:discover": "bun run --cwd packages/runtime discover",
    "runtime:service": "bun run --cwd packages/runtime service",
    "voice:bridge": "bun run --cwd packages/voice bridge",
    "voice:check": "bun run --cwd packages/voice check",
    "site:docs": "bun run --cwd packages/relay/relay-docs dev"
  },
  "dependencies": {
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "electron",
    "sharp",
    "unrs-resolver"
  ]
}
