{
  "name": "openscout",
  "version": "0.2.13",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:full-stack",
    "dev:full-stack": "npm --prefix packages/electron-app run dev:full-stack",
    "dev:web": "npm --prefix packages/electron-app run dev:web",
    "dev:electron": "npm --prefix packages/electron-app run dev:electron",
    "build": "npm run electron:build",
    "check": "npm run protocol:check && bun run --cwd apps/desktop check && npm run electron:check && npm run runtime:check && bun run cloud:check",
    "start": "npm run electron",
    "electron": "npm --prefix packages/electron-app run electron",
    "electron:build": "npm run protocol:build && npm run runtime:build && npm --prefix packages/electron-app run build && npm --prefix packages/electron-app run build:electron",
    "electron:check": "npm --prefix packages/electron-app run check",
    "electron:dev": "npm --prefix packages/electron-app run dev:full-stack",
    "electron:import-v0": "npm --prefix packages/electron-app run import:v0",
    "electron:stage-v0": "npm --prefix packages/electron-app run stage:v0",
    "electron:diff-v0": "npm --prefix packages/electron-app run diff:v0",
    "electron:apply-v0": "npm --prefix packages/electron-app run apply:v0",
    "electron:package": "npm --prefix packages/electron-app run package:macos",
    "release": "node scripts/release.mjs",
    "electron:web": "npm --prefix packages/electron-app run electron:web",
    "cli:build": "npm run protocol:build && npm run runtime:build && npm --prefix packages/cli run build",
    "web:build": "npm --prefix packages/web run build",
    "web:dev": "npm --prefix packages/web run dev",
    "server": "bun run apps/desktop/src/server/control-plane-index.ts",
    "cli:dev": "npm --prefix packages/cli run dev",
    "test:happy": "cd apps/desktop && bun run test:happy && cd ../../packages/electron-app && bun run test:happy && cd ../cli && bun run test:happy",
    "protocol:build": "npm --prefix packages/protocol run build",
    "protocol:check": "npm --prefix packages/protocol run check",
    "runtime:broker": "npm --prefix packages/runtime run broker",
    "runtime:build": "npm run protocol:build && npm --prefix packages/runtime run build",
    "runtime:check": "npm --prefix packages/runtime run check",
    "runtime:discover": "npm --prefix packages/runtime run discover",
    "runtime:service": "npm --prefix packages/runtime run service",
    "ios:buildPhone": "bash apps/ios/scripts/build-device.sh",
    "ios:devPhone": "bash apps/ios/scripts/install-last-build.sh",
    "ios:pushPhone": "bash apps/ios/scripts/push-device.sh",
    "ship:ios": "bash apps/ios/scripts/release.sh",
    "ship:mac": "bash packages/electron-app/scripts/ship-macos.sh",
    "ship:app": "bash packages/electron-app/scripts/ship-macos.sh",
    "ship:npm": "bash scripts/ship-npm.sh",
    "ship": "bun run ship:ios & bun run ship:mac & wait",
    "landing:build": "cd landing && bun install && bun run build",
    "landing:dev": "cd landing && bun install && bun run dev",
    "cloud:build": "cd apps/cloud && bun run build",
    "cloud:check": "cd apps/cloud && bun run check",
    "cloud:dev": "cd apps/cloud && bun run dev",
    "cloud:start": "cd apps/cloud && bun run start",
    "api:build": "bun run cloud:build",
    "api:check": "bun run cloud:check",
    "api:dev": "bun run cloud:dev",
    "api:start": "bun run cloud:start"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "electron",
    "sharp",
    "unrs-resolver"
  ]
}
