{
  "name": "openscout",
  "version": "0.2.75",
  "private": true,
  "packageManager": "bun@1.3.13",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arach/openscout.git"
  },
  "bugs": {
    "url": "https://github.com/arach/openscout/issues"
  },
  "homepage": "https://github.com/arach/openscout#readme",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --cwd packages/web dev",
    "dev:m1": "bun run --cwd packages/web dev:m1",
    "dev:m1:http": "bun run --cwd packages/web dev:m1:http",
    "dev:m1:https": "bun run --cwd packages/web dev:m1:https",
    "dev:edge": "bun run --cwd packages/web dev:edge",
    "dev:edge:m1": "bun run --cwd packages/web dev:edge:m1",
    "dev:edge:m1:http": "bun run --cwd packages/web dev:edge:m1:http",
    "dev:edge:m1:https": "bun run --cwd packages/web dev:edge:m1:https",
    "menu": "bun ./apps/macos/bin/openscout-menu.ts launch",
    "scout:dev": "bun ./apps/macos/bin/scout-app.ts restart",
    "scout:build": "bun ./apps/macos/bin/scout-app.ts dev-build",
    "scout:launch": "bun ./apps/macos/bin/scout-app.ts launch",
    "scout:status": "bun ./apps/macos/bin/scout-app.ts status",
    "scout:tui": "bun packages/cli/src/main.ts tui",
    "build": "bun run cli:build && bun run web:build",
    "check": "bun run sync-exec:fence && bun run protocol:check && bun run --cwd apps/desktop check && bun run runtime:check && bun run cloud:check && bun run mesh-front-door:check",
    "sync-exec:fence": "bun scripts/check-sync-exec-fence.ts",
    "test": "bun run test:unit",
    "test:unit": "bun run --cwd packages/protocol test && bun run --cwd packages/agent-sessions test && bun test ./packages/runtime/src --path-ignore-patterns='**/*live.test.ts' --path-ignore-patterns='**/scenario-suite.test.ts' && bun run --cwd apps/mesh-front-door test && bun run --cwd apps/desktop test && bun run --cwd packages/web test && bun run --cwd packages/session-trace test && bun run --cwd packages/session-trace-react test",
    "test:happy": "cd apps/desktop && bun run test:happy && cd ../../packages/cli && bun run test:happy",
    "test:scenarios": "bun run --cwd packages/runtime test:scenarios",
    "test:e2e": "bun run check && bun run test:scenarios && bun run test:e2e:agents",
    "test:e2e:agents": "bun run --cwd packages/runtime test:e2e:local-agent-pass",
    "test:live:agents": "bun run --cwd packages/runtime test:live:local-agent-pass",
    "cursor:transport-spike": "bun scripts/cursor-transport-spike.mjs",
    "pi:minimax": "bash scripts/pi-minimax-headless.sh",
    "pi:minimax:up": "bun scripts/pi-minimax-up.mjs",
    "pi:minimax:restart": "bun scripts/pi-minimax-up.mjs --restart",
    "pi:minimax:down": "bun scripts/pi-minimax-up.mjs --down",
    "cli:build": "bun run protocol:build && bun run runtime:build && bun run --cwd packages/cli build",
    "cli:dev": "bun run --cwd packages/cli dev",
    "web:build": "bun run --cwd packages/web build",
    "protocol:build": "bun run --cwd packages/protocol build",
    "protocol:check": "bun run --cwd packages/protocol check",
    "runtime:build": "bun run protocol:build && bun run --cwd packages/runtime build",
    "runtime:check": "bun run --cwd packages/runtime check",
    "runtime:broker": "bun run --cwd packages/runtime broker",
    "runtime:discover": "bun run --cwd packages/runtime discover",
    "runtime:service": "bun run --cwd packages/runtime service",
    "scoutd:fmt": "bash scripts/cargo.sh fmt --all --check",
    "scoutd:check": "bash scripts/cargo.sh check --manifest-path crates/scoutd/Cargo.toml",
    "scoutd:test": "bash scripts/cargo.sh test --manifest-path crates/scoutd/Cargo.toml",
    "scoutd:build": "bash scripts/cargo.sh build --manifest-path crates/scoutd/Cargo.toml",
    "scoutd:sign": "bash scripts/sign-scoutd.sh",
    "scoutd:run": "bash scripts/cargo.sh run --manifest-path crates/scoutd/Cargo.toml --",
    "scoutd:supervise": "bash scripts/cargo.sh run --manifest-path crates/scoutd/Cargo.toml -- supervise",
    "scoutd:verify": "bash scripts/scoutd-verify.sh",
    "repo-service:fmt": "bash scripts/cargo.sh fmt --manifest-path crates/openscout-repo-service/Cargo.toml --check",
    "repo-service:check": "bash scripts/cargo.sh check --manifest-path crates/openscout-repo-service/Cargo.toml",
    "repo-service:test": "bash scripts/cargo.sh test --manifest-path crates/openscout-repo-service/Cargo.toml",
    "repo-service:build": "bash scripts/cargo.sh build --manifest-path crates/openscout-repo-service/Cargo.toml",
    "repo-service:run": "bash scripts/cargo.sh run --manifest-path crates/openscout-repo-service/Cargo.toml --",
    "mesh:iroh:smoke": "bun scripts/mesh-iroh-smoke.mjs",
    "mesh-front-door:check": "bun run --cwd apps/mesh-front-door check",
    "mesh-front-door:dev": "bun run --cwd apps/mesh-front-door dev",
    "mesh-front-door:test": "bun run --cwd apps/mesh-front-door test",
    "dev:cleanup": "bash scripts/dev-cleanup.sh",
    "dev:cleanup:ports": "bash scripts/dev-cleanup.sh --ports-only",
    "restart:all": "bun scripts/restart-all.mjs",
    "cloud:build": "cd apps/cloud && bun run build",
    "cloud:check": "cd apps/cloud && bun run check",
    "cloud:dev": "cd apps/cloud && bun run dev",
    "cloud:start": "cd apps/cloud && bun run start",
    "landing:build": "bun run --cwd landing/openscout.app build",
    "landing:dev": "bun run --cwd landing/openscout.app dev",
    "docs:agent": "bun scripts/generate-agent-docs.mjs",
    "logs:event-types": "bun run --cwd packages/agent-sessions event-types",
    "macos:build": "bun ./apps/macos/bin/openscout-menu.ts build",
    "macos:launch": "bun ./apps/macos/bin/openscout-menu.ts launch",
    "macos:restart": "bun ./apps/macos/bin/openscout-menu.ts restart",
    "macos:dmg": "bun ./apps/macos/bin/openscout-menu.ts dmg",
    "macos:verify-dmg": "node scripts/verify-macos-dmg.mjs",
    "macos:upload-dmg": "node scripts/upload-macos-dmg-release.mjs",
    "ios:build": "bash apps/ios/scripts/build-device.sh",
    "ios:install": "bash apps/ios/scripts/install-last-build.sh",
    "ios:push": "bash apps/ios/scripts/push-device.sh",
    "ios:run": "bun apps/ios/hkit.ts run apps/ios/hkit.json",
    "ios:hkit:build": "bun apps/ios/hkit.ts build apps/ios/hkit.json",
    "ship:ios": "bash apps/ios/scripts/release.sh",
    "ship:macos": "node scripts/ship-macos-dmg.mjs",
    "ship:npm": "bash scripts/ship-npm.sh",
    "ship:release": "node scripts/ship-release.mjs",
    "ship": "node scripts/ship-release.mjs",
    "bump": "node scripts/bump-version.mjs"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
