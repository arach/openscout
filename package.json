{
  "name": "openscout",
  "version": "0.2.64",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --cwd packages/web dev",
    "dev:m1": "bun run --cwd packages/web dev:m1",
    "dev:m1:http": "bun run --cwd packages/web dev:m1:http",
    "dev:m1:https": "bun run --cwd packages/web dev:m1:https",
    "dev:edge": "bun run --cwd packages/web dev:edge",
    "dev:edge:m1": "bun run --cwd packages/web dev:edge:m1",
    "dev:edge:m1:http": "bun run --cwd packages/web dev:edge:m1:http",
    "dev:edge:m1:https": "bun run --cwd packages/web dev:edge:m1:https",
    "menu": "bun ./apps/macos/bin/openscout-menu.ts launch",
    "build": "npm run cli:build && npm run web:build",
    "check": "npm run protocol:check && bun run --cwd apps/desktop check && npm run runtime:check && bun run cloud:check",
    "test:happy": "cd apps/desktop && bun run test:happy && cd ../../packages/cli && bun run test:happy",
    "test:scenarios": "npm --prefix packages/runtime run test:scenarios",
    "test:e2e": "bun run check && bun run test:scenarios && bun run test:e2e:agents",
    "test:e2e:agents": "bun run --cwd packages/runtime test:e2e:local-agent-pass",
    "test:live:agents": "bun run --cwd packages/runtime test:live:local-agent-pass",
    "pi:minimax": "bash scripts/pi-minimax-headless.sh",
    "pi:minimax:up": "bun scripts/pi-minimax-up.mjs",
    "pi:minimax:restart": "bun scripts/pi-minimax-up.mjs --restart",
    "pi:minimax:down": "bun scripts/pi-minimax-up.mjs --down",
    "cli:build": "npm run protocol:build && npm run runtime:build && npm --prefix packages/cli run build",
    "cli:dev": "npm --prefix packages/cli run dev",
    "web:build": "npm --prefix packages/web run build",
    "protocol:build": "npm --prefix packages/protocol run build",
    "protocol:check": "npm --prefix packages/protocol run check",
    "runtime:build": "npm run protocol:build && npm --prefix packages/runtime run build",
    "runtime:check": "npm --prefix packages/runtime run check",
    "runtime:broker": "npm --prefix packages/runtime run broker",
    "runtime:discover": "npm --prefix packages/runtime run discover",
    "runtime:service": "npm --prefix packages/runtime run service",
    "mesh:iroh:smoke": "bun scripts/mesh-iroh-smoke.mjs",
    "dev:cleanup": "bash scripts/dev-cleanup.sh",
    "dev:cleanup:ports": "bash scripts/dev-cleanup.sh --ports-only",
    "cloud:build": "cd apps/cloud && bun run build",
    "cloud:check": "cd apps/cloud && bun run check",
    "cloud:dev": "cd apps/cloud && bun run dev",
    "cloud:start": "cd apps/cloud && bun run start",
    "landing:build": "cd landing && bun install && bun run build",
    "landing:dev": "cd landing && bun install && bun run dev",
    "macos:build": "bun ./apps/macos/bin/openscout-menu.ts build",
    "macos:launch": "bun ./apps/macos/bin/openscout-menu.ts launch",
    "macos:restart": "bun ./apps/macos/bin/openscout-menu.ts restart",
    "macos:dmg": "bun ./apps/macos/bin/openscout-menu.ts dmg",
    "ios:build": "bash apps/ios/scripts/build-device.sh",
    "ios:install": "bash apps/ios/scripts/install-last-build.sh",
    "ios:push": "bash apps/ios/scripts/push-device.sh",
    "ship:ios": "bash apps/ios/scripts/release.sh",
    "ship:npm": "bash scripts/ship-npm.sh",
    "ship:release": "node scripts/ship-release.mjs",
    "ship": "node scripts/ship-release.mjs",
    "bump": "node scripts/bump-version.mjs"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
