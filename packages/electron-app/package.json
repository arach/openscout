{
  "name": "@openscout/electron-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "productName": "OpenScout",
  "bundleId": "com.openscout.desktop",
  "scripts": {
    "dev": "node scripts/dev-electron.mjs",
    "dev:renderer": "vite",
    "import:v0": "node scripts/import-v0.mjs stage",
    "stage:v0": "node scripts/import-v0.mjs stage",
    "diff:v0": "node scripts/import-v0.mjs diff",
    "apply:v0": "node scripts/import-v0.mjs apply",
    "build": "bun run build:client && bun run build:ssr && bun run build:server",
    "build:client": "vite build --outDir dist/client",
    "build:ssr": "vite build --ssr src/entry-server.tsx --outDir dist/server",
    "build:server": "tsup server/index.ts --format esm --out-dir dist --target node22 --splitting false",
    "build:electron": "tsup electron/main.ts --format esm --out-dir dist/electron --target node22 --splitting false --external electron && mkdir -p dist/electron && cp electron/preload.cjs dist/electron/preload.cjs",
    "build:static": "vite build --outDir dist/static",
    "package:macos": "bun run build && bun run build:electron && node scripts/package-macos-app.mjs",
    "start": "NODE_ENV=production bun dist/index.js",
    "electron": "bun run build && bun run build:electron && electron dist/electron/main.js",
    "electron:web": "bun run build:electron && electron dist/electron/main.js",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@openscout/runtime": "workspace:*",
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-alert-dialog": "1.1.15",
    "@radix-ui/react-aspect-ratio": "1.1.8",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-context-menu": "2.2.16",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-hover-card": "1.1.15",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-menubar": "1.1.16",
    "@radix-ui/react-navigation-menu": "1.2.14",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-progress": "1.1.8",
    "@radix-ui/react-radio-group": "1.3.8",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slider": "1.3.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-toast": "1.2.15",
    "@radix-ui/react-toggle": "1.1.10",
    "@radix-ui/react-toggle-group": "1.1.11",
    "@radix-ui/react-tooltip": "1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.1.0",
    "embla-carousel-react": "8.6.0",
    "express": "^5.1.0",
    "input-otp": "1.4.2",
    "lucide-react": "^0.577.0",
    "motion": "^12.23.24",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-day-picker": "9.13.2",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.54.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^2.1.7",
    "recharts": "2.15.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^1.7.1",
    "tailwind-merge": "^3.3.1",
    "vaul": "^1.1.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.1",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "electron": "^37.5.1",
    "tailwindcss": "^4.1.14",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "tw-animate-css": "1.3.3"
  }
}
