{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "types": ["node", "bun-types"],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@scout/app": ["../../apps/scout/src/app/index.ts"],
      "@scout/app/*": ["../../apps/scout/src/*"],
      "@/*": ["../../apps/scout/src/ui/desktop/*"],
      "@openscout/runtime/*": ["../runtime/src/*"],
      "@openscout/protocol/*": ["../protocol/src/*"]
    }
  },
  "include": ["electron", "server", "vite.config.ts"]
}
