  "types": "./dist/index.d.ts",
  "files": [
    "bin",
    "dist",
    "src",
    "!src/**/*.test.ts",
    "!src/**/test-helpers/**",
    "drizzle",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm --prefix ../agent-sessions run build && rm -rf dist && node_modules/.bin/tsc -p tsconfig.json",
    "broker": "node ./bin/openscout-runtime.mjs broker",
    "service": "node ./bin/openscout-runtime.mjs service",
    "discover": "node ./bin/openscout-runtime.mjs discover",
    "db:generate": "bunx drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "bun ./src/drizzle-migrate.ts",
    "check": "npm --prefix ../agent-sessions run build && tsc --noEmit -p tsconfig.json",
    "test": "bun test src/*.test.ts",
    "test:scenarios": "bun test src/scenario-suite.test.ts",
    "test:live:codex-app-server": "bun test src/codex-app-server-live.test.ts",
    "test:e2e:local-agent-pass": "bash ../../scripts/run-live-local-agent-pass.sh",
    "test:live:local-agent-pass": "bash ../../scripts/run-live-local-agent-pass.sh",
    "prepack": "npm run build && node ../../scripts/prepare-publish-manifest.mjs .",
    "postpack": "node ../../scripts/restore-publish-manifest.mjs .",
    "postpublish": "node ../../scripts/restore-publish-manifest.mjs ."
  },
  "dependencies": {
    "@openscout/agent-sessions": "workspace:*",
    "@openscout/protocol": "workspace:*",
    "@trpc/server": "^11.16.0",
    "drizzle-orm": "^0.45.2",
    "smol-toml": "^1.6.1",
    "ws": "^8.18.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cursor/sdk": "1.0.13",
    "@types/node": "^22",
    "@types/ws": "^8.5.13",
    "bun-types": "^1.3.11",
    "drizzle-kit": "0.31.10",
    "typescript": "^5"
  },
  "license": "MIT",
  "author": "Arach Tchoupani",
  "homepage": "https://github.com/arach/openscout/tree/main/packages/runtime#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arach/openscout.git",
    "directory": "packages/runtime"
  },
  "bugs": {
    "url": "https://github.com/arach/openscout/issues"
  },
  "keywords": [
    "openscout",
    "runtime",
    "agents",
    "broker",
    "control-plane",
    "local-first",
    "typescript"
  ],
  "engines": {
    "node": ">=22"
  }
}
