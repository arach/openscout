{
  "name": "@openscout/runtime",
  "version": "0.0.0",
  "private": true,
  "description": "Local runtime foundation for the OpenScout control plane",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "bun": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./setup": {
      "types": "./dist/setup.d.ts",
      "bun": "./src/setup.ts",
      "default": "./dist/setup.js"
    },
    "./project-twins": {
      "types": "./dist/project-twins.d.ts",
      "bun": "./src/project-twins.ts",
      "default": "./dist/project-twins.js"
    }
  },
  "types": "./src/index.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "broker": "bun run src/broker-daemon.ts",
    "service": "bun run src/broker-service.ts",
    "discover": "bun run src/mesh-discover.ts",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "bun test src/*.test.ts"
  },
  "dependencies": {
    "@openscout/protocol": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5"
  }
}
