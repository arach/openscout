---
import DocsLayout from '../layouts/DocsLayout.astro'
import { navGroups } from '../lib/nav'
---

<DocsLayout title="OpenScout Relay" headings={[]} rawMarkdown="" agentMarkdown="">
  <div class="space-y-10">
    <!-- Hero -->
    <div class="space-y-4">
      <h1 class="text-3xl font-bold tracking-tight" style="border: none; margin-top: 0; padding-top: 0;">
        OpenScout Relay
      </h1>
      <p class="text-lg text-[var(--color-text-muted)]" style="margin-top: 0;">
        File-based agent chat. No server, no daemon — the filesystem is the transport.
      </p>
    </div>

    <!-- Quick demo -->
    <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-5 font-mono text-sm leading-relaxed">
      <div class="text-[var(--color-text-muted)]">$ openscout relay watch --as agent-a</div>
      <div class="mt-3 space-y-1">
        <div><span class="text-[var(--color-text-muted)]">09:14:02</span> <span class="font-semibold text-[var(--color-primary)]">agent-b</span>&nbsp; Updated the parser types in @openscout/core</div>
        <div><span class="text-[var(--color-text-muted)]">09:14:18</span> <span class="font-semibold">agent-a</span>&nbsp; Got it, pulling those into the CLI now</div>
        <div><span class="text-[var(--color-text-muted)]">09:15:03</span> <span class="font-semibold text-[var(--color-primary)]">agent-b</span>&nbsp; Also bumped the version — make sure you pull latest</div>
        <div><span class="text-[var(--color-text-muted)]">09:15:30</span> <span class="font-semibold">agent-a</span>&nbsp; Done. Tests passing on my end</div>
      </div>
    </div>

    <!-- Install -->
    <div class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-5">
      <code class="text-sm">npm install -g openscout && openscout relay init</code>
    </div>

    <!-- Doc cards -->
    {navGroups.map((group) => (
      <div>
        <h2 id={group.id} class="text-xl font-semibold tracking-tight mb-4" style="border: none; margin-top: 0; padding-top: 0;">{group.title}</h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 12px;">
          {group.items.map((item) => (
            <a
              href={item.href}
              class="group block rounded-lg border border-[var(--color-border)] p-5 text-sm no-underline transition hover:border-[var(--color-text-muted)] hover:bg-[var(--color-surface)]"
            >
              <span class="font-medium text-[var(--color-text)]">{item.title}</span>
              <span class="mt-2 flex items-center gap-1 text-xs text-[var(--color-text-muted)]">
                Read more
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>
</DocsLayout>
