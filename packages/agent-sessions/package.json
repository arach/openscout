{
  "name": "@openscout/agent-sessions",
  "version": "0.2.57",
  "description": "Browser-safe session boundary for OpenScout agent sessions",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "bun": "./src/client.ts",
      "default": "./dist/client.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "bun test src/*.test.ts src/protocol/*.test.ts src/adapters/**/*.test.ts",
    "adapter:validate-specs": "node ./src/adapters/spec/tools/validate-adapter-specs.mjs",
    "codex:extract-protocol": "node ./src/adapters/codex/tools/extract-rust-protocol-spec.mjs",
    "prepack": "npm run build && node ../../scripts/prepare-publish-manifest.mjs .",
    "postpublish": "node ../../scripts/restore-publish-manifest.mjs ."
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22",
    "bun-types": "^1.3.11",
    "typescript": "^5"
  }
}
