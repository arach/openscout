{
  "$schema": "../spec/adapter-spec.v1.schema.json",
  "specVersion": "1.0.0",
  "adapterId": "claude-code",
  "displayName": "Claude Code",
  "implementation": {
    "package": "@openscout/agent-sessions",
    "entrypoint": "src/adapters/claude-code.ts",
    "factoryExport": "createAdapter",
    "className": "ClaudeCodeAdapter"
  },
  "upstream": {
    "kind": "cli_protocol",
    "name": "Claude Code stream-json CLI",
    "transport": "stream-json-stdio",
    "sources": [
      {
        "kind": "file",
        "ref": "src/adapters/claude-code.ts"
      },
      {
        "kind": "file",
        "ref": "src/adapters/claude-code/references/current-implementation-protocol.md"
      },
      {
        "kind": "comment",
        "ref": "src/adapters/claude-code.ts",
        "notes": "Header comment documents the stream-json input and output event shapes consumed by the current adapter."
      }
    ]
  },
  "sessionModel": {
    "lifecycle": "long_lived_process",
    "conversationScope": "session",
    "resumeSupport": "optional",
    "resumeOptionKey": "resume",
    "turnSteering": "implicit_followup",
    "concurrentTurns": "unspecified",
    "persistence": [
      "process_state",
      "upstream_session_id"
    ]
  },
  "capabilities": {
    "promptInputs": {
      "text": true,
      "images": "embedded",
      "files": "reference_text"
    },
    "outputBlocks": [
      "text",
      "reasoning",
      "action",
      "error",
      "question"
    ],
    "actionKinds": [
      "command",
      "file_change",
      "subagent",
      "tool_call"
    ],
    "streaming": {
      "text": false,
      "reasoning": false,
      "actionOutput": true,
      "actionStatus": true
    },
    "interactive": {
      "questions": "native",
      "approvals": "none",
      "serverRequests": "none"
    },
    "control": {
      "interrupt": true,
      "shutdown": true
    }
  },
  "nativeProtocol": {
    "outboundRequests": [
      "user",
      "tool_result"
    ],
    "outboundNotifications": [],
    "inboundNotifications": [
      "system",
      "assistant",
      "tool_use",
      "tool_result",
      "result",
      "error"
    ],
    "inboundServerRequests": [],
    "messageFormats": [
      "stream_json_message",
      "user_message",
      "assistant_message",
      "tool_use",
      "tool_result",
      "result"
    ],
    "serverRequestStrategy": "not_applicable"
  },
  "normalizedSurface": {
    "adapterMethods": [
      "start",
      "send",
      "interrupt",
      "shutdown"
    ],
    "optionalAdapterMethods": [
      "answerQuestion"
    ],
    "emitsPairingEvents": [
      "session:update",
      "turn:start",
      "block:start",
      "block:action:output",
      "block:action:status",
      "block:question:answer",
      "block:end",
      "turn:end"
    ]
  },
  "limitations": [
    "The adapter ignores stream_event partial deltas, so assistant text and reasoning are surfaced as completed blocks instead of incremental deltas.",
    "Referenced files are appended to the prompt as plain text notes rather than being sent through a native file attachment channel.",
    "The adapter does not expose a normalized approval surface and does not implement decide()."
  ]
}
