{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "types": ["bun-types"],
    "paths": {
      "react": ["./node_modules/@types/react/index.d.ts"],
      "react-dom": ["./node_modules/@types/react-dom/index.d.ts"],
      "react-dom/*": ["./node_modules/@types/react-dom/*"],
      "react/jsx-runtime": ["./node_modules/@types/react/jsx-runtime.d.ts"],
      "react/jsx-dev-runtime": ["./node_modules/@types/react/jsx-dev-runtime.d.ts"],
      "@hudsonkit": ["../../../hudson/packages/web/hudsonkit/src/index.ts"],
      "@hudsonkit/app-shell": ["../../../hudson/packages/web/hudsonkit/src/app-shell.ts"],
      "@hudsonkit/shell": ["../../../hudson/packages/web/hudsonkit/src/shell.ts"],
      "@hudsonkit/chrome": ["../../../hudson/packages/web/hudsonkit/src/chrome.ts"],
      "@hudsonkit/controls": ["../../../hudson/packages/web/hudsonkit/src/controls.ts"],
      "@hudsonkit/canvas": ["../../../hudson/packages/web/hudsonkit/src/canvas.ts"],
      "@hudsonkit/overlays": ["../../../hudson/packages/web/hudsonkit/src/overlays.ts"],
      "@hudsonkit/vault": ["../../../hudson/packages/web/hudsonkit/src/vault.ts"],
      "@hudsonkit/styles": ["../../../hudson/packages/web/hudsonkit/src/styles/bundle.css"]
    }
  },
  "include": ["client/**/*.ts", "client/**/*.tsx", "server/**/*.ts", "vite.config.ts"],
  "exclude": ["server/**/*.test.ts"]
}
