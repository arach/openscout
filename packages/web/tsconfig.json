{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "types": ["bun-types"],
    "paths": {
      "react": ["./node_modules/@types/react/index.d.ts"],
      "react-dom": ["./node_modules/@types/react-dom/index.d.ts"],
      "react-dom/*": ["./node_modules/@types/react-dom/*"],
      "react/jsx-runtime": ["./node_modules/@types/react/jsx-runtime.d.ts"],
      "react/jsx-dev-runtime": ["./node_modules/@types/react/jsx-dev-runtime.d.ts"],
      "@hudsonkit": [
        "../../../hudson/packages/web/hudsonkit/src/index.ts",
        "./node_modules/hudsonkit/dist/index.d.ts"
      ],
      "@hudsonkit/app-shell": [
        "../../../hudson/packages/web/hudsonkit/src/app-shell.ts",
        "./node_modules/hudsonkit/dist/app-shell.d.ts"
      ],
      "@hudsonkit/shell": [
        "../../../hudson/packages/web/hudsonkit/src/shell.ts",
        "./node_modules/hudsonkit/dist/shell.d.ts"
      ],
      "@hudsonkit/chrome": [
        "../../../hudson/packages/web/hudsonkit/src/chrome.ts",
        "./node_modules/hudsonkit/dist/chrome.d.ts"
      ],
      "@hudsonkit/controls": [
        "../../../hudson/packages/web/hudsonkit/src/controls.ts",
        "./node_modules/hudsonkit/dist/controls.d.ts"
      ],
      "@hudsonkit/canvas": [
        "../../../hudson/packages/web/hudsonkit/src/canvas.ts",
        "./node_modules/hudsonkit/dist/canvas.d.ts"
      ],
      "@hudsonkit/overlays": [
        "../../../hudson/packages/web/hudsonkit/src/overlays.ts",
        "./node_modules/hudsonkit/dist/overlays.d.ts"
      ],
      "hudsonkit/flags": [
        "../../../hudson/packages/web/hudsonkit/src/flags/index.ts",
        "./node_modules/hudsonkit/dist/flags.d.ts"
      ],
      "@hudsonkit/styles": [
        "../../../hudson/packages/web/hudsonkit/src/styles/bundle.css",
        "./node_modules/hudsonkit/dist/styles.css"
      ]
    }
  },
  "include": ["client/**/*.ts", "client/**/*.tsx", "server/**/*.ts", "vite.config.ts"],
  "exclude": ["server/**/*.test.ts"]
}
