{
  "name": "@openscout/web",
  "version": "0.2.56",
  "description": "Standalone lightweight Scout web UI with its own bundled Bun server",
  "license": "UNLICENSED",
  "type": "module",
  "bin": {
    "openscout-web": "./bin/openscout-web.mjs"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "build:client": "vite build",
    "build:server": "bun build ./server/index.ts --target=bun --format=esm --outfile ./dist/openscout-web-server.mjs && bun build ./server/pair-supervisor.ts --target=bun --format=esm --outfile ./dist/pair-supervisor.mjs",
    "dev": "node ./scripts/dev.mjs",
    "dev:client": "vite --host 127.0.0.1 --port 5180 --strictPort",
    "dev:server": "OPENSCOUT_WEB_VITE_URL=http://127.0.0.1:5180 bun run --hot server/index.ts",
    "prepack": "npm run build && node ../../scripts/prepare-publish-manifest.mjs .",
    "postpublish": "node ../../scripts/restore-publish-manifest.mjs .",
    "test:happy": "node --test test/*.test.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.107",
    "@arach/arc": "^0.4.1",
    "ai": "^6.0.105",
    "lucide-react": "^0.577.0",
    "node-pty": "1.2.0-beta.12",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "uqr": "^0.1.2"
  },
  "devDependencies": {
    "@hono/trpc-server": "^0.4.2",
    "@tailwindcss/vite": "^4.1.18",
    "tailwindcss": "^4.1.18",
    "@noble/ciphers": "^2.1.1",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@openscout/agent-sessions": "0.2.56",
    "@openscout/protocol": "0.2.56",
    "@openscout/runtime": "0.2.56",
    "@trpc/server": "^11.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.0.0",
    "bun-types": "^1.3.11",
    "hono": "^4.12.10",
    "typescript": "^5",
    "vite": "^7.0.0",
    "zod": "^4.3.6"
  }
}
