{
  "name": "@openscout/web",
  "version": "0.2.64",
  "private": true,
  "description": "Standalone lightweight Scout web UI with its own bundled Bun server",
  "license": "UNLICENSED",
  "type": "module",
  "bin": {
    "openscout-web": "./bin/openscout-web.mjs"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "build:client": "vite build",
    "build:server": "node ./scripts/sync-terminal-relay-session.mjs --check && bun build ./server/index.ts --target=bun --format=esm --outfile ./dist/openscout-web-server.mjs && bun build ./server/pair-supervisor.ts --target=bun --format=esm --outfile ./dist/pair-supervisor.mjs && bun build ./server/terminal-relay-node.ts --target=node --format=esm --outfile ./dist/openscout-terminal-relay.mjs --external node-pty",
    "dev": "node ./scripts/dev.mjs",
    "dev:cleanup:ports": "bash ../../scripts/dev-cleanup.sh --ports-only",
    "relay:check": "node ./scripts/sync-terminal-relay-session.mjs --check",
    "relay:sync": "node ./scripts/sync-terminal-relay-session.mjs",
    "dev:client": "vite --host 127.0.0.1 --port 5180 --strictPort",
    "dev:server": "OPENSCOUT_WEB_VITE_URL=http://127.0.0.1:5180 bun run --hot server/index.ts",
    "prepack": "npm run build && node ../../scripts/prepare-publish-manifest.mjs .",
    "postpack": "node ../../scripts/restore-publish-manifest.mjs .",
    "postpublish": "node ../../scripts/restore-publish-manifest.mjs .",
    "test:happy": "node --test test/*.test.mjs"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.107",
    "@arach/arc": "^0.4.1",
    "@voxd/client": "^0.2.1",
    "ai": "^6.0.105",
    "lucide-react": "^0.577.0",
    "node-pty": "1.2.0-beta.12",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "uqr": "^0.1.2",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@hono/trpc-server": "^0.4.2",
    "@noble/ciphers": "^2.1.1",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@openscout/agent-sessions": "workspace:*",
    "@openscout/protocol": "workspace:*",
    "@openscout/runtime": "workspace:*",
    "@tailwindcss/vite": "^4.1.18",
    "@trpc/client": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "bun-types": "^1.3.11",
    "hono": "^4.12.10",
    "tailwindcss": "^4.1.18",
    "typescript": "^5",
    "vite": "^7.0.0",
    "zod": "^4.3.6"
  }
}
