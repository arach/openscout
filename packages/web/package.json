{
  "name": "@openscout/web",
  "version": "0.2.21",
  "description": "Standalone lightweight Scout web UI with its own bundled Bun server",
  "license": "UNLICENSED",
  "type": "module",
  "bin": {
    "openscout-web": "./bin/openscout-web.mjs"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "build:client": "vite build",
    "build:server": "bun build ./server/index.ts --target=bun --format=esm --outfile ./dist/openscout-web-server.mjs && bun build ./server/pair-supervisor.ts --target=bun --format=esm --outfile ./dist/pair-supervisor.mjs",
    "dev": "vite",
    "prepack": "npm run build",
    "test:happy": "node --test test/*.test.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "uqr": "^0.1.2"
  },
  "devDependencies": {
    "@hono/trpc-server": "^0.4.2",
    "@noble/ciphers": "^2.1.1",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@openscout/protocol": "workspace:*",
    "@openscout/runtime": "workspace:*",
    "@trpc/server": "^11.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.0.0",
    "bun-types": "^1.3.11",
    "hono": "^4.12.10",
    "typescript": "^5",
    "vite": "^7.0.0",
    "zod": "^4.3.6"
  }
}
