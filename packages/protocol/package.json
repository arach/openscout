{
  "name": "@openscout/protocol",
  "version": "0.2.77",
  "description": "Typed protocol for the OpenScout local control plane",
  "license": "Apache-2.0",
  "type": "module",
  "author": "Arach Tchoupani",
  "homepage": "https://github.com/arach/openscout/tree/main/packages/protocol#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arach/openscout.git",
    "directory": "packages/protocol"
  },
  "bugs": {
    "url": "https://github.com/arach/openscout/issues"
  },
  "keywords": [
    "openscout",
    "protocol",
    "agents",
    "broker",
    "control-plane",
    "a2a",
    "typescript"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "bun test src/*.test.ts",
    "prepack": "npm run build && node ../../scripts/prepare-publish-manifest.mjs .",
    "postpack": "node ../../scripts/restore-publish-manifest.mjs .",
    "postpublish": "node ../../scripts/restore-publish-manifest.mjs ."
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
