{
  "name": "@openscout/cli",
  "version": "0.2.0",
  "description": "Published Scout CLI package that installs the `scout` command",
  "license": "UNLICENSED",
  "type": "module",
  "bin": {
    "scout": "./bin/scout.mjs"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm --prefix ../runtime run build && node ./scripts/build.mjs",
    "dev": "bun ../../apps/scout/bin/scout.ts",
    "test:happy": "node --test test/*.test.mjs",
    "prepack": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@openscout/runtime": "workspace:*"
  }
}
